# MongoDB
MONGODB_URI=mongodb://localhost:27017/browsermind

# Server
PORT=3210

# Modelo padrão da IA (opções: gemini-flash-2.5, gemini-pro-2.5, gemini-flash-3, gemini-pro-3.1, gpt-4.1, claude-sonnet, deepseek)
DEFAULT_MODEL=gemini-flash-3

# API Keys (opcional — também pode configurar pela UI)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
